{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ESP32-DIV V1",
            "type": "shell",
            "command": "platformio run",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                {
                    "owner": "cpp",
                    "fileLocation": ["relative", "${workspaceFolder}"],
                    "pattern": {
                        "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                        "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
                    }
                }
            ],
            "presentation": {
                "echo": true, "reveal": "always", "focus": false,
                "panel": "shared", "clear": false
            }
        },
        {
            "label": "Flash ESP32-DIV V1",
            "type": "shell",
            "command": "platformio run --target upload",
            "group": "build",
            "presentation": {
                "echo": true, "reveal": "always", "focus": false, "panel": "shared"
            }
        },
        {
            "label": "Monitor Serial",
            "type": "shell",
            "command": "platformio device monitor",
            "presentation": {
                "echo": true, "reveal": "always", "focus": true, "panel": "shared"
            }
        }
    ]
}
